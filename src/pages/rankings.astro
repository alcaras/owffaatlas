---
import Base from '../layouts/Base.astro';
import dist from '../data/ffa-dist.json';
const baseUrl = import.meta.env.BASE_URL;
const configs = (dist as any).configs as any[];

type Dim = { key: string; label: string; unit: string; low?: boolean };
const FAIR: Dim[] = [
  { key: 'fairScore', label: 'Fairness', unit: '/100 (higher = fairer)' },
  { key: 'collideMean', label: 'Collision distance', unit: 'moves to first neighbour' },
  { key: 'collideCV', label: 'Collision spread', unit: 'CV — lower is fairer', low: true },
  { key: 'terrYieldCV', label: 'Territory-yield spread', unit: 'CV — lower is fairer', low: true },
  { key: 'terrYieldMean', label: 'Territory yield', unit: 'pre-collision, per player' },
  { key: 'badPct', label: 'Bad starts', unit: '% stranded or tiny-island — lower is fairer', low: true },
  { key: 'isolPct', label: 'Stranded starts', unit: '% alone on a landmass — lower is fairer', low: true },
  { key: 'islandPct', label: 'Tiny-island starts', unit: '% on a ≤4-site island — lower is fairer', low: true },
  { key: 'clusterMin', label: 'Smallest cluster', unit: 'fewest players per landmass (1 = someone alone)' },
  { key: 'landmasses', label: 'Landmasses w/ starts', unit: 'count' },
  { key: 'spreadMean', label: 'Start spread', unit: 'mean hex between starts' },
];
const MAP: Dim[] = [
  { key: 'sites', label: 'City sites', unit: 'on the map' },
  { key: 'expansion', label: 'Expansion space', unit: 'urbanizable tiles' },
  { key: 'hills', label: 'Hills / windmill', unit: 'hill tiles' },
  { key: 'land', label: 'Land tiles', unit: 'walkable land' },
];
const RES: Dim[] = [
  { key: 'grain', label: 'Grain', unit: '' }, { key: 'pasture', label: 'Pasture', unit: '' },
  { key: 'camp', label: 'Camp', unit: '' }, { key: 'grove', label: 'Grove', unit: '' },
  { key: 'nets', label: 'Nets', unit: '' }, { key: 'ore', label: 'Ore', unit: '' },
  { key: 'precious', label: 'Precious', unit: '' }, { key: 'marble', label: 'Marble', unit: '' },
  { key: 'horse', label: 'Horses', unit: '' }, { key: 'ele', label: 'Elephants', unit: '' },
  { key: 'camel', label: 'Camels', unit: '' },
];
const YIELD: Dim[] = [
  { key: 'food', label: 'Food', unit: 'potential' }, { key: 'iron', label: 'Iron', unit: 'potential' },
  { key: 'stone', label: 'Stone', unit: 'potential' }, { key: 'wood', label: 'Wood', unit: 'potential' },
];
const TERR: Dim[] = [
  { key: 'nomad', label: 'Nomad', unit: '% arid/sand' }, { key: 'trees', label: 'Trees', unit: '% tiles' },
  { key: 'jungle', label: 'Jungle', unit: '% tiles' }, { key: 'marsh', label: 'Marsh', unit: '% tiles' },
  { key: 'scrub', label: 'Scrub', unit: '% tiles' }, { key: 'veg', label: 'Vegetation', unit: '% tiles' },
  { key: 'hillsPct', label: 'Hills %', unit: '% tiles' }, { key: 'river', label: 'River borders', unit: '% tiles' },
  { key: 'rangedCover', label: 'Ranged cover', unit: 'veg penalty idx' },
  { key: 'clearcutSF', label: 'Clearcut: scrub+forest', unit: 'wood' },
  { key: 'clearcutWJ', label: 'Clearcut: +jungle', unit: 'wood' },
];
const GROUPS = [
  { title: 'FFA fairness', sub: 'collision-model balance of the 10 starts', dims: FAIR },
  { title: 'Map & space', sub: 'sites / land', dims: MAP },
  { title: 'Resources', dims: RES, sub: 'count per map' },
  { title: 'Yield potential', dims: YIELD, sub: 'food / iron / stone / wood' },
  { title: 'Terrain', dims: TERR, sub: '% of tiles & combat terrain' },
];

const nameOf = (c: any) => c.group;
const subOf = (c: any) => c.aspect[0].toUpperCase() + c.aspect.slice(1);
function ranked(key: string, low = false) {
  const rows = configs.map((c) => {
    const d = c.dist?.[key]; const none = !d || (d.max ?? 0) <= 0;
    return { c, v: d?.mean ?? 0, none };
  });
  const vals = rows.map((r) => r.v); const lo = Math.min(...vals), hi = Math.max(...vals);
  // best-first: low-is-better → ascending; else descending
  rows.sort((a, b) => low ? a.v - b.v : b.v - a.v);
  return rows.map((r, i) => {
    let t = hi > lo ? (r.v - lo) / (hi - lo) : 0.5;
    if (low) t = 1 - t;                 // low value = green / full bar
    const tt = Math.max(0, Math.min(1, t));
    return { ...r, rank: i + 1, w: r.none ? 100 : Math.round(8 + tt * 92),
      col: r.none ? '#23262c' : `hsl(${Math.round(tt * 125)},58%,42%)` };
  });
}
const tip = (c: any, k: string) => { const d = c.dist?.[k];
  return d ? `avg ${d.mean} ±${d.sd} (${d.min}–${d.max})` : 'n/a'; };
---
<Base title="FFA Rankings">
  <p class="lede">Every FFA config (7 scripts × Square/Wide, huge, 10 players) ranked on each
    dimension, best → worst. Bars are relative within each list. <b>Fairness</b> leads:
    a map is good when the 10 starts share a similar collision distance and pre-collision
    territory yield. <a href={baseUrl}>← atlas</a></p>
  <div class="rlayout">
    <nav class="snav" id="snav">
      {GROUPS.map((g) => (<div class="snav__sec"><div class="snav__t">{g.title}</div>
        {g.dims.map((dim) => (<a class="snav__l" data-key={dim.key} href={`#r-${dim.key}`}>{dim.label}</a>))}
      </div>))}
    </nav>
    <div class="rmain">
      {GROUPS.map((g) => (
        <section class="grp">
          <div class="grp__h"><h2 class="grp__t">{g.title}</h2><span class="grp__sub">{g.sub}</span></div>
          <div class="cards">
            {g.dims.map((dim) => (
              <div class="lbcard" id={`r-${dim.key}`}>
                <div class="lbcard__h"><span class="lbcard__t">{dim.label}</span>
                  {dim.unit && <span class="lbcard__u">{dim.unit}</span>}</div>
                <ol class="lb">
                  {ranked(dim.key, dim.low).map((r) => (
                    <li class={`r${r.none ? ' r--none' : ''}`} title={tip(r.c, dim.key)}>
                      <span class="r__n">{r.rank}</span>
                      <span class="r__nm"><b>{nameOf(r.c)}</b><i>{subOf(r.c)}</i></span>
                      <span class="r__bar"><span style={`width:${r.w}%;background:${r.col}`}></span></span>
                      <span class="r__v">{r.none ? '0' : r.v}</span>
                    </li>))}
                </ol>
              </div>))}
          </div>
        </section>))}
    </div>
  </div>

  <style>
    .lede { font-family:var(--font-display); font-style:italic; font-size:1.05rem; line-height:1.55;
      color:var(--text-soft); max-width:90ch; margin:0.6rem 0 1.2rem; }
    .rlayout { display:grid; grid-template-columns:184px 1fr; gap:1.4rem; align-items:start; }
    @media (max-width:860px){ .rlayout{ grid-template-columns:1fr; } }
    .rmain { min-width:0; }
    .snav { position:sticky; top:8px; align-self:start; max-height:calc(100vh - 24px); overflow:auto;
      display:flex; flex-direction:column; gap:0.1rem; }
    @media (max-width:860px){ .snav{ position:static; flex-flow:row wrap; max-height:none; margin-bottom:0.6rem; } }
    .snav__sec { margin-bottom:0.6rem; }
    .snav__t { font-size:0.58rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--gold-soft);
      margin-bottom:0.25rem; font-weight:700; }
    .snav__l { display:block; color:var(--text-soft); text-decoration:none; font-size:0.74rem;
      line-height:1.2; padding:0.12rem 0.4rem; border-radius:4px; border-left:2px solid transparent; }
    .snav__l:hover { color:var(--gold); background:var(--bg-elev); text-decoration:none; }
    .snav__l.on { color:var(--gold); font-weight:700; border-left-color:var(--gold); background:var(--bg-elev); }
    .grp { margin:0 0 2rem; scroll-margin-top:8px; }
    .grp__h { display:flex; align-items:baseline; gap:0.7rem; flex-wrap:wrap;
      border-bottom:1px solid var(--gold-deep); padding-bottom:0.3rem; margin-bottom:0.9rem; }
    .grp__t { font-family:var(--font-display); font-weight:700; font-size:1.5rem; color:var(--gold); }
    .grp__sub { font-family:var(--font-display); font-style:italic; font-size:0.9rem; color:var(--text-faint); }
    .cards { display:grid; gap:1rem; grid-template-columns:repeat(auto-fill, minmax(330px, 1fr)); }
    .lbcard { background:var(--bg-elev); border:1px solid var(--border); border-radius:8px;
      padding:0.7rem 0.85rem 0.5rem; scroll-margin-top:8px; }
    .lbcard__h { display:flex; align-items:center; gap:0.5rem; border-bottom:1px solid var(--border);
      padding-bottom:0.45rem; margin-bottom:0.4rem; }
    .lbcard__t { font-family:var(--font-display); font-weight:700; font-size:1.15rem; color:var(--text); }
    .lbcard__u { margin-left:auto; font-size:0.56rem; letter-spacing:0.08em; text-transform:uppercase;
      color:var(--text-dim); font-family:var(--font-mono); text-align:right; }
    .lb { list-style:none; margin:0; padding:0; }
    .r { display:grid; grid-template-columns:1.4rem 1fr 64px 2.7rem; align-items:center; gap:0.5rem; padding:0.16rem 0; }
    .r__n { font-family:var(--font-mono); font-size:0.7rem; color:var(--text-dim); text-align:right; }
    .r:nth-child(1) .r__n { color:var(--gold); font-weight:700; }
    .r:nth-child(2) .r__n, .r:nth-child(3) .r__n { color:var(--gold-soft); }
    .r__nm { min-width:0; display:flex; flex-direction:column; line-height:1.1; }
    .r__nm b { font-weight:600; font-size:0.82rem; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .r__nm i { font-style:normal; font-size:0.6rem; color:var(--text-dim); font-family:var(--font-mono); }
    .r__bar { height:7px; border-radius:4px; background:#0e0f12; border:1px solid var(--border); overflow:hidden; }
    .r__bar span { display:block; height:100%; border-radius:4px 0 0 4px; box-shadow:inset 0 0 0 1px #0006; }
    .r__v { font-family:var(--font-mono); font-size:0.78rem; color:var(--text-soft); text-align:right; }
    .r--none { opacity:0.4; } .r--none .r__bar { border-style:dashed; } .r--none .r__v { color:var(--text-dim); }
  </style>
  <script is:inline>
    (function () {
      var links = [].slice.call(document.querySelectorAll('.snav__l'));
      var cards = links.map(function (l) { return document.getElementById('r-' + l.getAttribute('data-key')); });
      var lock = null;
      function active(i) { links.forEach(function (l, j) { l.classList.toggle('on', j === i); }); }
      links.forEach(function (l) { l.addEventListener('click', function () { lock = l.getAttribute('data-key'); spy(); }); });
      function spy() {
        var bt = -1e9, grp = [];
        cards.forEach(function (s, i) { if (!s) return; var t = s.getBoundingClientRect().top - 60;
          if (t > 0) return; if (t > bt + 1) { bt = t; grp = [i]; } else if (Math.abs(t - bt) <= 1) grp.push(i); });
        if (!grp.length) { active(0); return; }
        var pick = grp[0];
        if (lock) { var f = grp.find(function (i) { return links[i].getAttribute('data-key') === lock; });
          if (f != null) pick = f; else lock = null; }
        active(pick);
      }
      window.addEventListener('scroll', function () { window.requestAnimationFrame(spy); }, { passive: true });
      spy();
    })();
  </script>
</Base>
